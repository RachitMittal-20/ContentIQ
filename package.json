{
  "name": "contentiq",
  "version": "0.1.0",
  "private": true,
  "workspaces": [],
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c purple,cyan \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start",
    "lint": "echo \"No lint configured\""
  },
  "dependencies": {
    "concurrently": "^9.1.0"
  }
}

